extends ../layout

block content
    style.
      .container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100%;
        margin-bottom: 20px;
        
      }
      #ClassForm {
        background-color: #fff;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        width: 600px;
        font-family: var(--poppins);
      }
      h2 {
        margin-bottom: 20px;
        color: #64b1f0;
      }

      .form-group {
        margin-bottom: 15px;
      }
      label {
        display: block;
        margin-bottom: 5px;
      }
      input, select {
        width: 100%;
        padding: 8px;
        box-sizing: border-box;
      }
      button {
        background-color: #64b1f0;
        color: white;
        padding: 10px 15px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
      }
    section#sidebar
      a.brand(href="#")
        i.bx.bxs-smile.bx-lg
        span.text AdminHub
      ul.side-menu.top
        li
          a(href="/home")
            i.bx.bxs-dashboard.bx-sm
            span.text Dashboard
        li
          a(href="/student")
            i.bx.bxs-user.bx-sm
            span.text Students
        li
          a(href="/teachers")
            i.bx.bxs-widget.bx-sm
            span.text Teachers
        li
          a(href="/parents")
            i.bx.bxs-user-pin.bx-sm
            span.text Parents
        li.active
          a(href="/class")
            i.bx.bxs-group.bx-sm
            span.text Classes
      ul.side-menu.bottom
        li
          a.logout(href="/logout")
            i.bx.bx-power-off.bx-sm.bx-burst-hover
            span.text Logout
    // SIDEBAR
    // CONTENT
    section#content
      // NAVBAR
      nav
        i.bx.bx-menu.bx-sm
        form(action="#")
          .form-input
            input(placeholder="Search..." type="search")
            button.search-btn(type="submit")
              i.bx.bx-search
        input#switch-mode.checkbox(hidden="" type="checkbox")
        label.swith-lm(for="switch-mode")
          i.bx.bxs-moon
          i.bx.bx-sun
          .ball
        // Profile Menu
        a#profileIcon.profile(href="#")
          img(alt="Profile" src="../images/user.png")
        #profileMenu.profile-menu
          ul
            li
              a(href="#") My Profile
            li
              a(href="#") Settings
            li
              a(href="/logout") Log Out
      // NAVBAR
      // MAIN
      main
        .head-title
          .left
            h1 Class
            ul.breadcrumb
              li
                a(href="/") Dashboard
              li
                i.bx.bx-chevron-right
              li
                a(href="#" style="color: #3acf32;") Class
        ul.box-info
          li
            i.bx.bxs-group
            span.text
              h3 1020
              p Total Students
          li
            i.bx.bxs-user
            span.text
              h3 2834
              p New Students (Current Month)
          li
            i.bx.bxs-group
            span.text
              h3 2543
              p Parents
    
    .container
      form#ClassForm(action="/add-class" method="POST")
        h2 Add Class
        .form-group
          label(for="className") Class Name:
          input#className(type="text" name="className" required)
        button(type="submit") Add Class