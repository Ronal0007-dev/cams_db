html(lang="en")
    head
        meta(charset='UTF-8')
        meta(name='viewport' content='width=device-width, initial-scale=1.0')
        link(rel='stylesheet' href='../stylesheets/login.css')
        title CAMS | ADMISSION
    body
        #loginLogo
            img(src='../images/login_logo.png' alt='Logo' style='width: 400px; height: 400px; margin:-70px 0 -150px 0; z-index: 1;')

        if success_msg
            for success in success_msg
                div.alert.alert-info #{ success }
        if error_msg
            for error in error_msg
                div.alert.alert-danger #{ error }
        //form            
        .container
            h1 Please Login
            form(action='/login' method='POST')
                .form-control
                    input(type='text' required='' name='mail')
                    label Email
                .form-control
                    input(type='password' required='' name='password')
                    label Password
                button.btn Login
    script(src='../javascripts/login.js')
